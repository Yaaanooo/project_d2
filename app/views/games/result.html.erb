<div class="result-page">

  <div class="result-container">

    <h1 class="result-title">クイズ結果</h1>

    <div class="genre-box">
      <h2><%= @genres.map(&:genre_name).join("・") %></h2>
    </div>

    <div class="score-box">
      <h3 class = "box-title">正解数</h3>
      <h2> <%= @correct_count %> / <%= @question_count %></h2>
    </div>

    <div class="comment-box">
    <h3 class = "box-title"></h3>
      <p><%= @comment %></p>
    </div>

    <div class="button-area">
      <%= button_to "リトライ",games_retry_path,method: :post, class: "result-button" %>
      <%= button_to "トップへ", root_path, method: :get, class: "result-button" %>
    </div>

  </div>
</div>