<!-- ==================================================
     クイズ結果画面
=================================================== -->

<div class="result-page">

  <!-- ==================================================
       結果画面コンテナ
  =================================================== -->
  <div class="result-container">

    <!-- タイトル -->
    <h1 class="result-title">クイズ結果</h1>

    <!-- ==================================================
         ジャンル
    =================================================== -->
    <div class="genre-box">
      <h3 class="box-title">ジャンル</h3>
      <h2><%= @genres.map(&:genre_name).join("・") %></h2>
    </div>

    <!-- ==================================================
         正解数
    =================================================== -->
    <div class="score-box">
      <h3 class="box-title">正解数</h3>
      <h2><%= @correct_count %> / <%= @question_count %></h2>
    </div>

    <!-- ==================================================
         コメント
    =================================================== -->
    <div class="comment-box">
      <h3 class="box-title">コメント</h3>
      <p><%= @comment %></p>
    </div>



    <!-- 詳細 -->
    <div class="details-area" style="text-align: center; margin-bottom: 20px;">
    <%= link_to "詳細を表示", games_details_path %>
    </div>

    <!-- ==================================================
         ボタンエリア
    =================================================== -->
    <div class="button-area">

      <!-- ===============================================
           リトライボタン
      ================================================ -->
      <div class="button-wrapper retry-wrapper">

        <!-- 吹き出し -->
        <div class="speech-bubble retry-bubble">
          もう一回！
        </div>

        <!-- ボタン -->
        <%= button_to "リトライ",
                      games_retry_path,
                      method: :post,
                      class: "result-button" %>

      </div>

      <!-- ===============================================
           トップへボタン
      ================================================ -->
      <div class="button-wrapper top-wrapper">

        <!-- 吹き出し -->
        <div class="speech-bubble top-bubble">
          また遊んでね！
        </div>

        <!-- ボタン -->
        <%= button_to "トップへ",
                      root_path,
                      method: :get,
                      class: "result-button" %>

      </div>

    </div>

  </div>

</div>