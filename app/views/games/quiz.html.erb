<div class="quiz-container">
  <div class="cancel-area">
    <%= button_to "中断", game_cancel_path, method: :post, form: {data: {turbo_confirm: "クイズを中断しますか？"}}, class: "cancel-button" %>
  </div>
  
  <div class="quiz-progress">
    <div class="progress-text">
      <%= @question_number %> / <%= @question_count %> 問
    </div>

    <div class="progress-segments">
      <% @question_count.times do |index| %>
        <% question_id = session[:question_ids][index] %>
        <% answered = session[:answers]&.key?(question_id.to_s) %>
        <% current = index == @question_number - 1 %>
        <% clickable = index <= (session[:max_question_index] || 0) %>

        <% classes = [
          "progress-segment",
          ("completed" if answered),
          ("current" if current),
          ("clickable" if clickable)
        ].compact.join(" ") %>

        <% if clickable %>
          <%= button_to "",
              game_jump_path(index: index),
              method: :post,
              class: classes,
              title: "問#{index + 1}へ移動",
              aria: { label: "問#{index + 1}へ移動" },
              form_class: "progress-form" %>
        <% else %>
          <div
            class="<%= classes %>"
            title="問<%= index + 1 %>"
          ></div>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="question-text">
    <div class="question-head">

      <div class="number-text">
        問<%= @question_number %>
      </div>

      <div class="genre-text">
        <%= @question&.genre&.genre_name || "ジャンル名" %>
      </div>

    </div>

    <div class="question-body">
      <%= @question&.body || "ここに問題文が入ります" %>
    </div>
  </div>

  <%= form_with url: game_next_path, method: :post, class: "quiz-form" do |form| %>

    <div class="answer-buttons">
      <% @choices.each_with_index do |choice, index| %>
        <% id = "choice_#{index}" %>

        <%= form.radio_button :user_answer_index,
                              index,
                              id: id,
                              required: true,
                              checked: !@selected_answer_index.nil? &&
                                       @selected_answer_index.to_i == index %>

        <%= form.label :user_answer_index,
                       choice,
                       for: id,
                       class: "answer-button" %>
      <% end %>
    </div>

    <div class="page-buttons">
      <%= form.button "◄ 前の問題",
          type: "submit",
          formaction: game_back_path,
          formmethod: "post",
          formnovalidate: true,
          class: "page-button #{"hidden-button" if @question_number == 1}" %>

      <% if @question_number == session[:question_ids].length %>
        <%= form.button "結果へ ►", type: "submit", class: "page-button" %>
      <% else %>
        <%= form.button "次の問題 ►", type: "submit", class: "page-button" %>
      <% end %>
    </div>

  <% end %>
</div>